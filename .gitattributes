# テキストファイルの改行コードを自動正規化（Win/Mac対応）
* text=auto

# ソースコード（LFに統一）
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# バイナリファイル（変換しない）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp3 binary
*.wav binary
*.ogg binary
*.mp4 binary
*.webm binary
*.ttf binary
*.woff binary
*.woff2 binary
*.jks binary
*.keystore binary
